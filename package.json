{
  "name": "zigi-command-board",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm --prefix ui run dev\" \"electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.zigicommandboard.app",
    "productName": "Zigi Command Board",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "parser/**/*",
      "Commands.ahk",
      "Allbuttons.ahk"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.14"
  }
}
